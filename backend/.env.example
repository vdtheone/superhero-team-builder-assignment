# =========================
# Backend (Python/Django)
# =========================
SUPERHERO_API_TOKEN=""

# Set to 'True' for local development, 'False' for production
DEBUG=True

# Comma-separated list of hosts that Django can serve, e.g., 'localhost,127.0.0.1,your.domain.com'
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of origins allowed to make cross-origin requests, e.g., 'http://localhost:5173,http://your.frontend.com'
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Set to 'True' to allow all origins for CORS (use with caution in production)
# CORS_ALLOW_ALL_ORIGINS=False

# Django Secret Key - Use a long, random string in production
SECRET_KEY=your_django_secret_key_here